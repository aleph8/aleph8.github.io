{
  "name": "web-graph-pandoc",
  "version": "1.0.0",
  "description": "Personal Web auto-generated using pandoc",
  "main": "src/index.js",
  "scripts": {
    "create": "npm run build",
    "serve": "cd dist && python3 -m http.server 12345",
    "clear": "rm -rf dist",
    "dev-scripts": "npx webpack --config webpack.dev.js",
    "prod-scripts": "npx webpack --config webpack.prod.js",
    "main-style": "mkdir -p dist/src && cp index.html dist && cp -r images dist",
    "graphs": "bash content_graphs_generator.sh",
    "gen-index": "cd dist && bash ../tools/get_json_publications.sh",
    "dev-build": "npm run clear && npm run main-style && npm run graphs && npm run dev-scripts && npm run gen-index",
    "prod-build": "npm run clear && npm run main-style && npm run graphs && npm run prod-scripts && npm run gen-index",
    "dev": "npm run build &&  tailwindcss -i ./src/css/tailwind.css -o ./dist/src/main.css --watch"
  },
  "author": "Aleph8",
  "license": "ISC",
  "dependencies": {
    "@tweenjs/tween.js": "19",
    "accessor-fn": "1",
    "autoprefixer": "^10.4.14",
    "babel-loader": "^9.1.3",
    "bezier-js": "3 - 6",
    "canvas-color-tracker": "1",
    "d3-array": "1 - 3",
    "d3-drag": "2 - 3",
    "d3-force-3d": "2 - 3",
    "d3-scale": "1 - 4",
    "d3-scale-chromatic": "1 - 3",
    "d3-selection": "2 - 3",
    "d3-zoom": "2 - 3",
    "index-array-by": "1",
    "kapsule": "^1.14",
    "lodash-es": "4",
    "lunr-languages": "^1.13.0"
  },
  "devDependencies": {
    "@fortawesome/fontawesome-free": "^6.4.2",
    "css-loader": "^6.8.1",
    "element-resize-detector": "^1.2.4",
    "force-graph": "^1.43.2",
    "lunr": "^2.3.9",
    "mini-css-extract-plugin": "^2.7.6",
    "postcss-cli": "^10.1.0",
    "postcss-loader": "^7.3.3",
    "style-loader": "^3.3.3",
    "tailwindcss": "^3.3.3",
    "terser-webpack-plugin": "^5.3.9",
    "webpack": "^5.88.1",
    "webpack-cli": "^5.1.4"
  }
}
