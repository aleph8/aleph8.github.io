---
import { getCollection } from 'astro:content';
import '../styles/global.css';

const posts   = await getCollection('posts', p => !p.data.draft && p.id.startsWith('en/'));
const docs    = await getCollection('projects',  d => d.id.startsWith('en/'));
const tags    = await getCollection('tags');

// Build graph data passed to the client
const gNodes: { id: string; label: string; type: string; url?: string; description?: string }[] = [];
const gLinks: { source: string; target: string }[] = [];

for (const tag of tags) {
  gNodes.push({ id: `tag:${tag.id}`, label: tag.data.name, type: 'tag', description: tag.data.description });
}

const projects = [...new Set(docs.map(d => d.id.split('/')[1]))];
for (const project of projects) {
  const intro = docs.find(d => d.id.startsWith(`en/${project}/intro`));
  gNodes.push({ id: `project:${project}`, label: project.toUpperCase(), type: 'project', url: `/projects/${project}/intro`, description: intro?.data.description ?? '' });
}

for (const post of posts) {
  const slug = post.id.split('/').slice(1).join('/').replace(/\.mdx?$/, '');
  gNodes.push({ id: `post:${post.id}`, label: post.data.title, type: 'post', url: `/blog/${slug}`, description: post.data.description });
  for (const tagRef of post.data.tags) {
    gLinks.push({ source: `post:${post.id}`, target: `tag:${tagRef.id}` });
  }
}

for (const doc of docs) {
  const project = doc.id.split('/')[1];
  const slug    = doc.id.split('/').slice(1).join('/').replace(/\.mdx?$/, '');
  gNodes.push({ id: `doc:${doc.id}`, label: doc.data.sidebar_label || doc.data.title, type: 'doc', url: `/projects/${slug}` });
  gLinks.push({ source: `doc:${doc.id}`, target: `project:${project}` });
}

const graphData = JSON.stringify({ nodes: gNodes, links: gLinks });
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Knowledge Graph - AGP</title>
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; }
    html, body { margin: 0; padding: 0; width: 100%; height: 100%; overflow: hidden; background: #050505; color: #fff; }
    body { font-family: 'JetBrains Mono', monospace; }
    #graph-canvas { display: block; width: 100vw; height: 100vh; }

    /* ── Shared HUD chrome ────────────────────────────────────────────── */
    .hud { position: fixed; pointer-events: none; z-index: 10; }
    .hud-top-left  { top: 28px; left: 32px; }
    .hud-top-right {
      top: 28px; right: 32px;
      pointer-events: all;
      display: flex; align-items: center; gap: 20px;
    }
    .hud-bottom-left  { bottom: 28px; left: 32px; }
    .hud-bottom-right {
      bottom: 28px; right: 32px;
      pointer-events: all;
    }

    .hud-title { font-size: 12px; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(255,255,255,0.55); line-height: 1.6; }
    .hud-title strong { display: block; font-size: 16px; color: rgba(255,255,255,0.9); letter-spacing: 0.1em; margin-bottom: 2px; }

    .hud-link {
      font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase;
      color: rgba(255,255,255,0.3); text-decoration: none; transition: color 0.15s;
    }
    .hud-link:hover { color: rgba(255,255,255,0.8); }

    /* ── Legend (explore mode) ────────────────────────────────────────── */
    #graph-legend { display: flex; flex-direction: column; gap: 7px; }
    .legend-item { display: flex; align-items: center; gap: 9px; font-size: 13px; letter-spacing: 0.1em; text-transform: uppercase; color: rgba(255,255,255,0.55); }
    .legend-dot  { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }

    /* ── Tooltip ──────────────────────────────────────────────────────── */
    #tooltip {
      position: fixed; pointer-events: none; z-index: 20;
      background: rgba(5,5,5,0.92); border: 1px solid rgba(255,255,255,0.08);
      padding: 10px 14px; max-width: 260px; display: none;
    }
    #tooltip .tt-type  { font-size: 11px; letter-spacing: 0.15em; text-transform: uppercase; color: rgba(255,255,255,0.4); margin-bottom: 6px; }
    #tooltip .tt-label { font-size: 15px; color: rgba(255,255,255,0.95); font-weight: 500; margin-bottom: 4px; line-height: 1.4; }
    #tooltip .tt-desc  { font-size: 12px; color: rgba(255,255,255,0.55); line-height: 1.5; letter-spacing: 0.03em; }
    #tooltip .tt-hint  { font-size: 11px; letter-spacing: 0.12em; color: rgba(102,126,234,0.9); margin-top: 7px; }

    /* ── SAVE THE KNOWLEDGE button ────────────────────────────────────── */
    #btn-save-knowledge {
      display: block;
      font-family: 'JetBrains Mono', monospace;
      font-size: 10px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--color-accent);
      background: transparent;
      border: 1px solid rgba(102,126,234,0.4);
      padding: 9px 16px;
      cursor: pointer;
      transition: all 0.2s;
      text-shadow: 0 0 8px rgba(102,126,234,0.6);
      box-shadow: 0 0 12px rgba(102,126,234,0.15);
    }
    #btn-save-knowledge:hover {
      background: rgba(102,126,234,0.12);
      border-color: rgba(102,126,234,0.7);
      box-shadow: 0 0 20px rgba(102,126,234,0.35);
      color: #fff;
    }

    /* ── Node-loss log (top-right, small) ────────────────────────────── */
    #node-loss-log {
      position: fixed; top: 58px; right: 32px; z-index: 25;
      display: flex; flex-direction: column; align-items: flex-end; gap: 5px;
      pointer-events: none;
    }
    .node-loss-entry {
      font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase;
      color: rgba(255, 80, 50, 0.85);
      animation: node-loss-fade 2.8s ease-out forwards;
    }
    @keyframes node-loss-fade {
      0%   { opacity: 1;   transform: translateY(0); }
      70%  { opacity: 0.6; transform: translateY(-5px); }
      100% { opacity: 0;   transform: translateY(-10px); }
    }

    /* ── In-game HUD bar ──────────────────────────────────────────────── */
    #game-hud {
      display: none;
      position: fixed; top: 0; left: 0; right: 0; z-index: 20;
      padding: 14px 28px;
      align-items: center; justify-content: space-between;
      background: linear-gradient(to bottom, rgba(5,5,5,0.85), transparent);
      pointer-events: none;
    }
    #game-hud > * { pointer-events: all; }

    .hud-section { display: flex; align-items: center; gap: 16px; }

    #hud-lives  { display: flex; gap: 6px; align-items: center; }
    #hud-lives svg { display: block; }

    .hud-label {
      font-size: 9px; letter-spacing: 0.2em; text-transform: uppercase;
      color: rgba(255,255,255,0.25); margin-right: 4px;
    }
    #hud-score-val, #hud-wave-val, #hud-coins-val {
      font-size: 13px; letter-spacing: 0.08em;
      color: rgba(255,255,255,0.7);
    }
    #hud-coins-val { color: #ffcc00; }

    #hud-controls-hint {
      font-size: 8px; letter-spacing: 0.12em; text-transform: uppercase;
      color: rgba(255,255,255,0.18);
    }

    #hud-weapon-badge {
      font-size: 9px; letter-spacing: 0.14em; text-transform: uppercase;
      padding: 2px 7px;
      border: 1px solid currentColor;
      opacity: 0.8;
    }

    #hud-modifiers {
      display: flex; gap: 5px; align-items: center;
      margin-left: 10px;
    }
    .mod-badge {
      font-size: 9px; letter-spacing: 0.12em; text-transform: uppercase;
      padding: 2px 6px;
      border: 1px solid currentColor;
      opacity: 0.85;
    }

    #btn-abort {
      font-family: 'JetBrains Mono', monospace;
      font-size: 9px; letter-spacing: 0.18em; text-transform: uppercase;
      color: rgba(255,68,34,0.6); background: transparent;
      border: 1px solid rgba(255,68,34,0.3);
      padding: 6px 12px; cursor: pointer; transition: all 0.15s;
    }
    #btn-abort:hover { color: #ff4422; border-color: rgba(255,68,34,0.7); }

    /* ── Wave banner ──────────────────────────────────────────────────── */
    #game-banner {
      display: none;
      position: fixed; inset: 0; z-index: 30;
      pointer-events: none;
      font-size: clamp(28px, 5vw, 48px);
      letter-spacing: 0.25em; text-transform: uppercase;
      color: rgba(255,255,255,0.9);
      text-shadow: 0 0 30px rgba(102,126,234,0.8), 0 0 60px rgba(102,126,234,0.4);
      display: none; align-items: center; justify-content: center;
      transition: opacity 0.4s;
    }

    /* ── Game overlay (game-over / victory) ───────────────────────────── */
    #game-overlay {
      display: none;
      position: fixed; inset: 0; z-index: 40;
      flex-direction: column; align-items: center; justify-content: center;
      gap: 16px;
      background: rgba(5,5,5,0.75);
      backdrop-filter: blur(2px);
    }
    #overlay-title {
      font-size: clamp(22px, 4vw, 38px);
      letter-spacing: 0.22em; text-transform: uppercase;
      color: #fff;
      text-shadow: 0 0 40px rgba(102,126,234,0.7);
    }
    #overlay-score {
      font-size: 13px; letter-spacing: 0.12em;
      color: rgba(255,255,255,0.45);
    }
    #overlay-nodes {
      font-size: 12px; letter-spacing: 0.1em;
      color: rgba(255,255,255,0.3);
      display: none;
    }
    .overlay-actions { display: flex; gap: 14px; margin-top: 8px; }
    .overlay-btn {
      font-family: 'JetBrains Mono', monospace;
      font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase;
      background: transparent; cursor: pointer; padding: 9px 20px; transition: all 0.2s;
    }
    #btn-play-again {
      color: #00ffcc; border: 1px solid rgba(0,255,204,0.45);
      text-shadow: 0 0 8px rgba(0,255,204,0.5);
    }
    #btn-play-again:hover { background: rgba(0,255,204,0.1); border-color: rgba(0,255,204,0.8); }
    #btn-victory-continue {
      color: var(--color-accent); border: 1px solid color-mix(in srgb, var(--color-accent) 45%, transparent);
      text-shadow: 0 0 8px rgba(102,126,234,0.5);
    }
    #btn-victory-continue:hover { background: rgba(102,126,234,0.1); border-color: rgba(102,126,234,0.8); }
    #btn-back-explore {
      color: rgba(255,255,255,0.4); border: 1px solid rgba(255,255,255,0.15);
    }
    #btn-back-explore:hover { color: rgba(255,255,255,0.8); border-color: rgba(255,255,255,0.4); }

    #overlay-highscore {
      font-size: 11px; letter-spacing: 0.14em;
      color: rgba(255,255,255,0.28);
    }
    #overlay-newrecord {
      font-size: 10px; letter-spacing: 0.22em; text-transform: uppercase;
      color: #ffcc00;
      text-shadow: 0 0 16px rgba(255,204,0,0.8);
      animation: new-record-pulse 1.2s ease-in-out infinite alternate;
    }
    @keyframes new-record-pulse {
      0%   { opacity: 0.7; text-shadow: 0 0 10px rgba(255,204,0,0.6); }
      100% { opacity: 1;   text-shadow: 0 0 24px rgba(255,204,0,1); }
    }

    /* ── Combo display (top-right corner, below nav) ─────────────────── */
    #hud-combo {
      position: fixed; top: 18px; right: 20px;
      display: none;
      flex-direction: row; align-items: baseline; gap: 6px;
      pointer-events: none; z-index: 25;
    }
    #hud-combo-val {
      font-size: clamp(20px, 2.8vw, 30px);
      font-weight: 700;
      letter-spacing: -0.01em;
      color: #ffcc00;
      text-shadow: 0 0 18px rgba(255,204,0,0.9), 0 0 36px rgba(255,204,0,0.4);
      line-height: 1;
    }
    #hud-combo-label {
      font-size: 9px; letter-spacing: 0.32em; text-transform: uppercase;
      color: rgba(255,204,0,0.5);
    }
    #hud-combo.combo-pop { animation: combo-pop 0.2s ease-out; }
    @keyframes combo-pop {
      0%   { transform: scale(1); }
      45%  { transform: scale(1.25); }
      100% { transform: scale(1); }
    }

    /* ── Shop overlay ─────────────────────────────────────────────────── */
    #shop-overlay {
      display: none;
      position: fixed; inset: 0; z-index: 40;
      flex-direction: column; align-items: center; justify-content: center;
      gap: 36px;
      background: rgba(2,2,10,0.96);
      backdrop-filter: blur(8px);
    }

    .shop-header {
      display: flex; flex-direction: column; align-items: center; gap: 10px;
    }
    #shop-title {
      font-size: clamp(11px, 1.8vw, 14px);
      letter-spacing: 0.55em; text-transform: uppercase;
      color: rgba(255,255,255,0.3);
    }
    .shop-header-row {
      display: flex; align-items: center; gap: 32px;
    }
    #shop-wave-display {
      font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase;
      color: rgba(255,255,255,0.25);
    }
    #shop-coins-display {
      font-size: 22px; letter-spacing: 0.08em;
      color: #ffcc00;
      text-shadow: 0 0 20px rgba(255,204,0,0.7), 0 0 40px rgba(255,204,0,0.3);
    }
    #shop-coins-display.coin-pop { animation: coin-pop 0.35s ease-out; }
    @keyframes coin-pop {
      0%   { transform: scale(1); }
      35%  { transform: scale(1.4); }
      100% { transform: scale(1); }
    }

    /* ── 3 cards side by side ────────────────────────────────────────── */
    #shop-items {
      display: flex; gap: 16px; flex-wrap: wrap; justify-content: center;
      padding: 0 24px;
    }

    .shop-card {
      position: relative;
      display: flex; flex-direction: column; align-items: center;
      gap: 12px;
      width: 180px; padding: 0 0 20px;
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.12);
      transition: transform 0.18s, box-shadow 0.18s, border-color 0.18s;
      cursor: default;
      overflow: hidden;
    }
    /* Colored top bar - the card's visual identity */
    .shop-card::before {
      content: '';
      display: block;
      width: 100%; height: 3px;
      background: var(--card-color, #ffcc00);
      box-shadow: 0 0 14px var(--card-color, #ffcc00),
                  0 0 30px var(--card-color, #ffcc00);
      flex-shrink: 0;
    }
    .shop-card:not(.shop-card--disabled):not(.shop-card--bought):hover {
      border-color: var(--card-color, rgba(255,204,0,0.6));
      transform: translateY(-5px);
      box-shadow: 0 12px 36px rgba(0,0,0,0.6), 0 0 28px rgba(0,0,0,0.3);
    }
    .shop-card--disabled {
      opacity: 0.3;
      filter: grayscale(0.5);
    }
    .shop-card--bought {
      border-color: #00ff8c !important;
    }
    .shop-card--bought::before {
      background: #00ff8c;
      box-shadow: 0 0 14px #00ff8c, 0 0 30px #00ff8c;
    }

    .shop-card-body {
      display: flex; flex-direction: column; align-items: center;
      gap: 10px; padding: 16px 16px 0; width: 100%; box-sizing: border-box;
    }

    .shop-card-icon {
      font-size: 30px; line-height: 1;
      text-shadow: 0 0 12px var(--card-color, rgba(255,204,0,0.8));
    }
    .shop-card-label {
      font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase;
      color: var(--card-color, #fff); text-align: center;
      text-shadow: 0 0 10px var(--card-color, transparent);
    }
    .shop-card--bought .shop-card-label { color: #00ff8c; }

    /* Level progress dots */
    .shop-card-level {
      font-size: 13px; letter-spacing: 0.12em;
      text-align: center; line-height: 1;
      opacity: 0.85;
    }

    .shop-card-desc {
      font-size: 9px; letter-spacing: 0.04em;
      color: rgba(255,255,255,0.38); text-align: center; line-height: 1.65;
      min-height: 30px;
    }

    .shop-card-divider {
      width: 100%; height: 1px;
      background: rgba(255,255,255,0.06);
    }

    .shop-card-footer {
      display: flex; align-items: center; justify-content: space-between;
      width: 100%; padding: 0 16px; box-sizing: border-box; gap: 8px;
    }
    .shop-card-cost {
      font-size: 15px; letter-spacing: 0.06em;
      color: #ffcc00;
      text-shadow: 0 0 8px rgba(255,204,0,0.5);
    }
    .shop-card--bought .shop-card-cost { color: rgba(0,255,140,0.7); }
    .shop-card--disabled .shop-card-cost { color: rgba(255,204,0,0.4); }

    .shop-buy-btn {
      font-family: 'JetBrains Mono', monospace;
      font-size: 9px; letter-spacing: 0.2em; text-transform: uppercase;
      background: transparent; cursor: pointer; padding: 7px 14px;
      border: 1px solid var(--card-color, rgba(255,204,0,0.6));
      color: var(--card-color, #ffcc00);
      transition: all 0.15s;
      white-space: nowrap;
    }
    .shop-buy-btn:hover:not(:disabled) {
      background: rgba(255,255,255,0.08);
      box-shadow: 0 0 14px var(--card-color, #ffcc00);
    }
    .shop-buy-btn:disabled { opacity: 0.3; cursor: not-allowed; }
    .shop-buy-btn.btn-acquired {
      color: #00ff8c;
      border-color: rgba(0,255,140,0.5);
      cursor: default;
    }

    /* Floating feedback text */
    .shop-float-text {
      position: absolute; top: 14px; left: 50%; transform: translateX(-50%);
      font-size: 9px; letter-spacing: 0.2em; text-transform: uppercase;
      color: #00ff8c; pointer-events: none;
      animation: float-up 1.1s ease-out forwards;
      white-space: nowrap;
    }
    @keyframes float-up {
      0%   { opacity: 1; transform: translateX(-50%) translateY(0); }
      100% { opacity: 0; transform: translateX(-50%) translateY(-28px); }
    }

    #btn-shop-skip {
      font-family: 'JetBrains Mono', monospace;
      font-size: 10px; letter-spacing: 0.22em; text-transform: uppercase;
      background: transparent; cursor: pointer; padding: 10px 26px;
      border: 1px solid rgba(255,255,255,0.14); color: rgba(255,255,255,0.32);
      transition: all 0.2s;
    }
    #btn-shop-skip:hover {
      color: rgba(255,255,255,0.7);
      border-color: rgba(255,255,255,0.35);
      background: rgba(255,255,255,0.04);
    }
  </style>
</head>
<body>

  <!-- ── Explore mode HUD ─────────────────────────────────────────────────── -->
  <div id="graph-title" class="hud hud-top-left">
    <div class="hud-title">
      <strong>AGP / Knowledge Graph</strong>
      Constellation of ideas
    </div>
  </div>

  <div class="hud hud-top-right">
    <a href="/es/" class="hud-link">ES</a>
    <a href="/"    class="hud-link">← Back</a>
  </div>

  <div id="graph-legend" class="hud hud-bottom-left">
    <div class="legend-item">
      <div class="legend-dot" style="background:var(--color-accent); box-shadow: 0 0 6px color-mix(in srgb, var(--color-accent) 53%, transparent);"></div>Post
    </div>
    <div class="legend-item">
      <div class="legend-dot" style="background:#a5b4fc; box-shadow: 0 0 6px #a5b4fc55;"></div>Project page
    </div>
    <div class="legend-item">
      <div class="legend-dot" style="background:#ffffff; box-shadow: 0 0 8px #fff6; width:10px; height:10px;"></div>Project
    </div>
    <div class="legend-item">
      <div class="legend-dot" style="background:#3d3d3d; border: 1px solid #666;"></div>Tag
    </div>
  </div>

  <!-- SAVE THE KNOWLEDGE button -->
  <div class="hud-bottom-right" style="position:fixed; bottom:28px; right:32px; z-index:10;">
    <button id="btn-save-knowledge">⬡ SAVE THE KNOWLEDGE</button>
  </div>

  <!-- ── Tooltip ──────────────────────────────────────────────────────────── -->
  <div id="tooltip">
    <div class="tt-type"  id="tt-type"></div>
    <div class="tt-label" id="tt-label"></div>
    <div class="tt-desc"  id="tt-desc"></div>
    <div class="tt-hint"  id="tt-hint"></div>
  </div>

  <!-- ── In-game HUD bar ──────────────────────────────────────────────────── -->
  <div id="game-hud">
    <div class="hud-section">
      <span class="hud-label">Lives</span>
      <div id="hud-lives"></div>
      <span class="hud-label" style="margin-left:12px;">Score</span>
      <span id="hud-score-val">000000</span>
      <span id="hud-weapon-badge" style="margin-left:14px;"></span>
      <div id="hud-modifiers"></div>
    </div>
    <div class="hud-section" style="flex-direction:column; align-items:center; gap:2px;">
      <div style="display:flex; align-items:center; gap:10px;">
        <span class="hud-label">Wave</span>
        <span id="hud-wave-val">-</span>
        <span class="hud-label" style="margin-left:8px;">¢</span>
        <span id="hud-coins-val">0</span>
      </div>
      <div id="hud-controls-hint">WASD move · IJKL / mouse aim · Space fire · Q weapon · F auto-fire</div>
    </div>
    <div class="hud-section">
      <button id="btn-abort">✕ Abort</button>
    </div>
  </div>

  <!-- ── Wave banner ──────────────────────────────────────────────────────── -->
  <div id="game-banner" style="display:none;"></div>

  <!-- ── Combo display (shown during game when combo ≥ 2) ─────────────────── -->
  <div id="hud-combo" style="display:none;">
    <span id="hud-combo-val">×2</span>
    <span id="hud-combo-label">COMBO</span>
  </div>

  <!-- ── Game overlay ─────────────────────────────────────────────────────── -->
  <div id="game-overlay" style="display:none;">
    <div id="overlay-title">KNOWLEDGE LOST</div>
    <div id="overlay-score">Score: 000000</div>
    <div id="overlay-nodes"></div>
    <div id="overlay-highscore" style="display:none;"></div>
    <span id="overlay-newrecord" style="display:none;">★ NEW RECORD</span>
    <div class="overlay-actions">
      <button class="overlay-btn" id="btn-play-again">↺ Play again</button>
      <button class="overlay-btn" id="btn-victory-continue" style="display:none;">→ Continue arcade</button>
      <button class="overlay-btn" id="btn-back-explore">← Explore</button>
    </div>
  </div>

  <!-- ── Shop overlay ─────────────────────────────────────────────────────── -->
  <div id="shop-overlay" style="display:none;">
    <div class="shop-header">
      <div id="shop-title">Upgrade Station</div>
      <div class="shop-header-row">
        <div id="shop-wave-display">Wave -</div>
        <div id="shop-coins-display">¢ 0</div>
      </div>
    </div>
    <!-- Item sections rendered dynamically by main.js -->
    <div id="shop-items"></div>
    <button id="btn-shop-skip">Continue →</button>
  </div>

  <!-- ── Node-loss log ───────────────────────────────────────────────────── -->
  <div id="node-loss-log"></div>

  <!-- ── Canvas ───────────────────────────────────────────────────────────── -->
  <canvas id="graph-canvas"></canvas>

  <!-- 1. Inject build-time data as a global (is:inline so it runs before the module) -->
  <script is:inline define:vars={{ graphData }}>
    window.__GRAPH_DATA = JSON.parse(graphData);
  </script>

  <!-- 2. Module entry point - Vite bundles this and all imports from src/invaders/ -->
  <script>
    import { init } from '../invaders/main.js';
    init();
  </script>

</body>
</html>
