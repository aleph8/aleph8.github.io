---
import BaseLayout from './BaseLayout.astro';
import { getEntry } from 'astro:content';
import { useTranslations, defaultLocale } from '../i18n/utils';
import { Image } from 'astro:assets';

const { frontmatter, lang = defaultLocale } = Astro.props;

const authorEntry = await getEntry(frontmatter.author);
const author = authorEntry?.data;

const tags = await Promise.all(frontmatter.tags.map((t: any) => getEntry(t)));

const formattedDate = frontmatter.pubDate.toLocaleDateString(lang, {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const t = useTranslations(lang as any);
const blogPath = lang === 'es' ? '/blog' : `/${lang}/blog`;
---

<BaseLayout title={frontmatter.title} description={frontmatter.description} ogImage={frontmatter.image} lang={lang} contentPage={true}>

  <article class="pt-4 md:pt-10 pb-16">

    <!-- Header -->
    <header class="mb-8 md:mb-12 max-w-2xl">
      <div class="flex flex-wrap items-center gap-x-3 gap-y-1 mb-5 text-sm text-neutral-500">
        <time class="font-mono text-xs" datetime={frontmatter.pubDate.toISOString()}>
          {formattedDate}
        </time>
        {tags.length > 0 && (
          <>
            <span class="text-neutral-300" aria-hidden="true">·</span>
            <div class="flex flex-wrap gap-2">
              {tags.map(tag => (
                <span class="font-mono text-xs tracking-wide">{tag?.data.name}</span>
              ))}
            </div>
          </>
        )}
      </div>

      <h1 class="text-2xl md:text-4xl font-semibold tracking-tight leading-snug mb-4">
        {frontmatter.title}
      </h1>

      <p class="text-neutral-500 text-base md:text-lg leading-relaxed">
        {frontmatter.description}
      </p>

      {author && (
        <div class="flex items-center gap-3 mt-6 pt-6 border-t border-neutral-100">
          {author.avatar && (
            <Image
              src={author.avatar}
              alt={author.name}
              width={100}
              height={100}
              format="webp"
              class="w-7 h-7 rounded-full"
              loading="lazy"
            />
          )}
          <span class="text-sm font-medium">{author.name}</span>
        </div>
      )}
    </header>

    <!-- Cover image -->
    {frontmatter.image && (
      <div class="mb-8 max-w-2xl">
        <a href={typeof frontmatter.image === 'string' ? frontmatter.image : frontmatter.image.src} target="_blank" class="block group/img">
          <Image
            src={frontmatter.image}
            alt={frontmatter.title}
            width={1200}
            height={600}
            format="webp"
            class="w-full h-48 md:h-80 object-cover rounded-sm border border-neutral-100 group-hover/img:border-accent/30 transition-all duration-300"
            loading="eager"
          />
        </a>
      </div>
    )}

    <!-- Content -->
    <div class="prose prose-neutral max-w-2xl
      prose-headings:font-semibold prose-headings:tracking-tight
      prose-a:text-accent prose-a:no-underline hover:prose-a:underline
      prose-code:font-mono prose-code:text-sm prose-code:bg-neutral-50 prose-code:px-1 prose-code:py-0.5 prose-code:rounded prose-code:text-black prose-code:before:content-none prose-code:after:content-none
      prose-pre:bg-neutral-950 prose-pre:text-neutral-100 prose-pre:rounded-none prose-pre:border-l-2 prose-pre:border-accent
      prose-blockquote:border-l-2 prose-blockquote:border-accent prose-blockquote:text-neutral-600 prose-blockquote:not-italic
      prose-img:rounded-sm prose-hr:border-neutral-100">
      <slot />
    </div>

    <!-- Back -->
    <div class="mt-12 pt-6 border-t border-neutral-100 max-w-2xl">
      <a href={blogPath} class="text-sm text-neutral-500 hover:text-black transition-colors duration-150">
        ← {t('blog.back')}
      </a>
    </div>

  </article>

</BaseLayout>
